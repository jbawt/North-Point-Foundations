# Copy to `.env` / `.env.local` as needed. Vite exposes only vars prefixed with VITE_.

# Mapbox (required for service-area maps)
# VITE_MAPBOX_ACCESS_TOKEN=
# VITE_MAPBOX_STYLE_URL=

# Public production origin — no path or trailing slash (used for canonical URLs, OG tags, JSON-LD, sitemap).
# Example: https://northpointfoundations.ca
# VITE_SITE_URL=

# Optional: Netlify form action when hosting the SPA elsewhere (see netlifyQuoteRequest / README).
# VITE_NETLIFY_FORM_ACTION=
